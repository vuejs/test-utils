{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:js-lib',
  ],
  prConcurrentLimit: 1,
  automerge: true,
  packageRules: [
    {
      groupName: 'vitest',
      matchPackageNames: [
        '@vitest/{/,}**',
        'vitest{/,}**',
      ],
    },
    {
      groupName: 'vite',
      matchPackageNames: [
        '@vitejs/{/,}**',
        'vite{/,}**',
        '!vitest{/,}**',
      ],
    },
    {
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      matchCurrentVersion: '>=1',
      groupName: 'all non-major dependencies',
      groupSlug: 'all-minor-patch',
      schedule: [
        'after 1am on Wednesday',
      ],
      matchPackageNames: [
        '*',
      ],
    },
  ],
}
